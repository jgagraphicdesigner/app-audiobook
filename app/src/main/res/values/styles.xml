<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base app theme -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">#1a0a2e</item>
        <item name="colorPrimaryDark">#1a0a2e</item>
        <item name="colorAccent">#f9c74f</item>
        <item name="android:windowBackground">#1a0a2e</item>
        <item name="android:statusBarColor">#1a0a2e</item>
        <item name="android:navigationBarColor">#1a0a2e</item>
    </style>

    <!-- Splash screen theme (fullscreen, no action bar) -->
    <style name="SplashTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">#1a0a2e</item>
        <item name="android:statusBarColor">#1a0a2e</item>
        <item name="android:navigationBarColor">#1a0a2e</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>

</resources>
